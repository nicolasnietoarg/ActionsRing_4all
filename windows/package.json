{
  "name": "actions-ring-windows",
  "version": "0.1.0",
  "description": "Actions Ring - Portable radial menu for Windows",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "esbuild src/renderer/index.jsx --bundle --outfile=dist/renderer.js --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:settings": "esbuild src/settings/index.jsx --bundle --outfile=dist/settings.js --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"production\\\"",
    "build": "npm run build:renderer && npm run build:settings",
    "dev": "npm run build && electron ."
  },
  "dependencies": {
    "lucide-react": "0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "31.3.1",
    "esbuild": "0.21.5"
  }
}
