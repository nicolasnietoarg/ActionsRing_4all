{
  "name": "actions-ring",
  "version": "0.1.0",
  "description": "Universal Actions Ring - radial menu overlay for any mouse/keyboard",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:renderer": "esbuild src/renderer/index.jsx --bundle --outfile=dist/renderer.js --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:settings": "esbuild src/settings/index.jsx --bundle --outfile=dist/settings.js --loader:.jsx=jsx --define:process.env.NODE_ENV=\\\"production\\\"",
    "build": "npm run build:renderer && npm run build:settings",
    "dev": "npm run build && electron .",
    "pack": "npm run build && electron-builder --mac --dir",
    "dist": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.actionsring.app",
    "productName": "Actions Ring",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "ring.png",
      "target": "dmg"
    },
    "files": [
      "src/**/*",
      "dist/**/*",
      "config/**/*",
      "tray-icon.png"
    ]
  },
  "dependencies": {
    "electron-store": "8.2.0",
    "lucide-react": "0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "31.3.1",
    "electron-builder": "24.13.3",
    "esbuild": "0.21.5"
  }
}
